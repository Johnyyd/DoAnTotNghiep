@GMP_System_HostAddress = https://localhost:7193

### -------------------------------------------------------
### BU?C 1: T?O MASTER DATA (NGUYĘN LI?U & CÔNG TH?C)
### -------------------------------------------------------

### 1. T?o Thŕnh Ph?m (Product): Panadol
# D? ki?n: ID = 1
POST {{GMP_System_HostAddress}}/api/Materials
Content-Type: application/json

{
  "materialCode": "PROD-PANADOL",
  "materialName": "Panadol Extra 500mg",
  "type": "FinishedGood", 
  "baseUomId": 1, 
  "description": "Thŕnh ph?m thu?c gi?m dau"
}

### 2. T?o Nguyęn Li?u (Raw Material): Tinh B?t
# D? ki?n: ID = 2
POST {{GMP_System_HostAddress}}/api/Materials
Content-Type: application/json

{
  "materialCode": "MAT-STARCH",
  "materialName": "Tinh b?t s?n (Starch)",
  "type": "RawMaterial",
  "baseUomId": 1
}

### 3. T?o Công Th?c (Recipe)
# Quy d?nh: Đ? lŕm ra Panadol (ID=1), c?n důng Tinh b?t (ID=2)
# D? ki?n RecipeID = 1
POST {{GMP_System_HostAddress}}/api/Recipes
Content-Type: application/json

{
  "materialId": 1,  
  "batchSize": 100000,
  "note": "Công th?c chu?n 2026",
  "recipeBoms": [
    {
      "materialId": 2, 
      "quantity": 50.0,
      "uomId": 1,
      "note": "Tá du?c d?n"
    }
  ]
}

### -------------------------------------------------------
### BU?C 2: L?P K? HO?CH S?N XU?T
### -------------------------------------------------------

### 4. L?p L?nh S?n Xu?t (Production Order)
# D?a tręn RecipeID = 1
# D? ki?n OrderID = 1
POST {{GMP_System_HostAddress}}/api/ProductionOrders
Content-Type: application/json

{
  "orderCode": "PO-2026-001",
  "recipeId": 1, 
  "plannedQuantity": 50000,
  "unitId": 1,
  "note": "L?nh SX d?u tięn"
}

### 5. Kh?i d?ng Lô s?n xu?t (Start Batch)
# D?a tręn OrderID = 1
# D? ki?n BatchID = 1
POST {{GMP_System_HostAddress}}/api/ProductionBatches
Content-Type: application/json

{
  "orderId": 1,
  "batchNumber": "BATCH-2026-001",
  "note": "Ca sáng"
}

### 6. Ghi nh?t ký v?n hŕnh (Log)
# Ghi cho BatchID = 1
POST {{GMP_System_HostAddress}}/api/BatchProcessLogs
Content-Type: application/json

{
  "batchID": 1, 
  "resultStatus": "Passed",
  "startTime": "2026-02-07T08:00:00",
  "endTime": "2026-02-07T08:30:00",
  "note": "Chu?n b? máy xong"
}

### -------------------------------------------------------
### BU?C 3: QU?N LÝ KHO (MUA HŔNG & C?P PHÁT)
### -------------------------------------------------------

### 7. Nh?p kho Nguyęn li?u Tinh B?t (ID=2)
# Mua Tinh b?t (ID=2) v? nh?p kho
# D? ki?n LotID = 1
POST {{GMP_System_HostAddress}}/api/InventoryLots
Content-Type: application/json

{
  "materialID": 2, 
  "lotNumber": "LOT-NCC-STARCH-01",
  "Quantity": 500.0,
  "expiryDate": "2028-01-01T00:00:00",
  "Status": "Quarantine" 
}

### 8. QC Duy?t Lô Nguyęn Li?u (Approve)
# Duy?t LotID = 1 sang tr?ng thái 'Released' d? du?c phép důng
POST {{GMP_System_HostAddress}}/api/InventoryLots/approve?lotId=1&status=Released

### 9. C?p phát Nguyęn li?u cho S?n xu?t (Dispense)
# L?y Tinh b?t t? Kho (LotID=1) d? vŕo Lô SX (BatchID=1)
# H?p l? vě: Công th?c (Bu?c 3) có ch?a Tinh b?t (ID=2)
POST {{GMP_System_HostAddress}}/api/MaterialUsages
Content-Type: application/json

{
  "batchID": 1,
  "inventoryLotID": 1, 
  "plannedAmount": 50.0,
  "actualAmount": 50.0,
  "note": "C?p phát 50kg Tinh b?t"
}

### 10. Ki?m tra l?i T?n kho
# T?n d?u 500 - C?p 50 = Cňn 450
GET {{GMP_System_HostAddress}}/api/InventoryLots/available



### -------------------------------------------------------
### BU?C 4: HOŔN T?T S?N XU?T & NH?P THŔNH PH?M
### -------------------------------------------------------

### 11. K?t thúc Lô s?n xu?t (Finish Batch)
# BatchID = 1 dă ch?y xong, gi? dóng l?i.
POST {{GMP_System_HostAddress}}/api/ProductionBatches/finish?batchId=1

### 12. Nh?p kho Thŕnh Ph?m (Finished Goods Receipt)
# Nh?p Panadol (ID=1) vŕo kho t? Lô SX s? 1
# Luu ý: Tr?ng thái ban d?u luôn lŕ 'Quarantine' (Ch? duy?t)
POST {{GMP_System_HostAddress}}/api/InventoryLots
Content-Type: application/json

{
  "materialID": 1, 
  "lotNumber": "LOT-PANADOL-2026-001",
  "Quantity": 100000, 
  "expiryDate": "2029-02-07T00:00:00",
  "Status": "Quarantine"
}

### 13. Ki?m tra t?n kho Thŕnh ph?m
# Xem Panadol (ID=1) dă vŕo kho chua?
GET {{GMP_System_HostAddress}}/api/InventoryLots/available
# Luu ý: N?u API "available" c?a b?n ch? hi?n lô 'Released', thě l?nh nŕy có th? tr? v? R?ng []
# Vě lô v?a nh?p dang lŕ 'Quarantine'. 

### 14. QC Duy?t Thŕnh Ph?m (Release Finished Goods)
# Sau khi ki?m nghi?m d?t, cho phép xu?t bán
POST {{GMP_System_HostAddress}}/api/InventoryLots/approve?lotId=2&status=Released
# Luu ý: LotId ? dây lŕ 2 (Vě Lot 1 lŕ Tinh b?t, Lot 2 lŕ Panadol m?i nh?p)

### 15. Ki?m tra l?i T?n kho (L?n cu?i)
# Bây gi? lô Panadol dă Released, nó ph?i hi?n ra
GET {{GMP_System_HostAddress}}/api/InventoryLots/available


### -------------------------------------------------------
### TEST AUDIT TRAIL (NH?T KÝ T? Đ?NG)
### -------------------------------------------------------

### 16. S?a tęn Nguyęn Li?u (Đ? xem h? th?ng có b?t du?c không)
# Đ?i tęn "Tinh b?t s?n" thŕnh "Tinh b?t Ngô cao c?p"
# Gi? s? Tinh b?t có ID = 2 (Hăy thay ID dúng c?a b?n vŕo URL)
PUT {{GMP_System_HostAddress}}/api/Materials/2
Content-Type: application/json

{
  "materialId": 2,
  "materialCode": "MAT-STARCH",
  "materialName": "Tinh b?t Ngô Cao C?p (Đă s?a)",
  "type": "RawMaterial",
  "baseUomId": 1
}

### Luu ý: N?u chua có API PUT (Update) cho Material, b?n có th? důng t?m
# API Duy?t Công Th?c ho?c API Finish Batch ? tręn d? test.
# Ho?c don gi?n nh?t: T?o thęm 1 Nguyęn li?u m?i.

### 17. T?o Nguyęn li?u test log
POST {{GMP_System_HostAddress}}/api/Materials
Content-Type: application/json

{
  "materialCode": "TEST-LOG",
  "materialName": "Test Audit Log",
  "type": "Packaging",
  "baseUomId": 1
}

### 18. XEM NH?T KÝ H? TH?NG (The Moment of Truth)
GET {{GMP_System_HostAddress}}/api/SystemAuditLogs
