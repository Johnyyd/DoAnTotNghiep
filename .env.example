# Example environment variables for PPMS Docker deployment
# --------------------------------------------------------
# SQL Server SA password (must meet SQL Server complexity requirements)
SA_PASSWORD=YourStrong@Passw0rd123

# JWT secret (256‑bit base64 string recommended)
JWT_KEY=GMP_WHO_Default_Secret_Key_Minimum_32_Characters_Long_123456789

# Database connection string used by the API
DB_CONNECTION=Server=gmp-sqlserver,1435;Database=PharmaceuticalProcessingManagementSystem;User Id=sa;Password=${SA_PASSWORD};
